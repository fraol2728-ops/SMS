# ================================
# REQUIRED - App will not start without these
# ================================

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here
CLERK_WEBHOOK_SECRET=whsec_your_secret_here

# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# App URL (used for email links and Clerk redirects)
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# Cron job protection
CRON_SECRET=your_high_entropy_secret_here

# Telegram bot token encryption key (min 32 chars)
TELEGRAM_TOKEN_SECRET=your_32_char_min_encryption_key_here

# ================================
# OPTIONAL - Features disabled if missing
# ================================

# Email notifications (Resend)
RESEND_API_KEY=re_your_key_here

# AI caption generation (Groq)
GROQ_API_KEY=gsk_your_key_here

# ================================
# CLERK URL CONFIG (defaults provided)
# ================================
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/
