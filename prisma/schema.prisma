generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  TEACHER
  STUDENT
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum ClassType {
  PERSONAL
  GROUP
}

enum TimeSlot {
  SLOT_8_10
  SLOT_10_12
  SLOT_12_2
  SLOT_3_5
  SLOT_5_7
}

enum ClassDays {
  MWF
  TTS
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  DROPPED
  ON_HOLD
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  MOBILE_MONEY
  CARD
}

enum ReportStatus {
  UNREAD
  READ
  REPLIED
}

enum NotificationTarget {
  ALL
  STUDENTS
  TEACHERS
  ADMIN
}

enum AssetCategory {
  COMPUTER
  MONITOR
  KEYBOARD
  MOUSE
  CHAIR
  TABLE
  NETWORK_SWITCH
  NETWORK_CABLE
  HEADSET
  WEBCAM
  PROJECTOR
  OTHER
}

enum AssetCondition {
  GOOD
  FAIR
  DAMAGED
  UNDER_REPAIR
  MISSING
  RETIRED
}

enum AssetLogAction {
  ADDED
  REPAIRED
  DAMAGED
  MISSING
  RETIRED
  UPDATED
  RETURNED
}

model Campus {
  id        String   @id @default(cuid())
  name      String   @unique
  location  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users   User[]
  courses Course[]
  classes Class[]
  labs    Lab[]
}

model Lab {
  id        String   @id @default(cuid())
  name      String
  campusId  String
  campus    Campus   @relation(fields: [campusId], references: [id])
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  classes Class[]
  assets  Asset[]

  @@unique([campusId, name])
}

model Asset {
  id           String         @id @default(cuid())
  labId        String
  lab          Lab            @relation(fields: [labId], references: [id], onDelete: Cascade)
  category     AssetCategory
  name         String
  serialNumber String?        @unique
  condition    AssetCondition @default(GOOD)
  notes        String?
  addedById    String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  logs AssetLog[]
}

model AssetLog {
  id        String         @id @default(cuid())
  assetId   String
  asset     Asset          @relation(fields: [assetId], references: [id], onDelete: Cascade)
  userId    String
  user      User           @relation(fields: [userId], references: [id])
  action    AssetLogAction
  note      String?
  createdAt DateTime       @default(now())
}

model Class {
  id          String         @id @default(cuid())
  campusId    String
  campus      Campus         @relation(fields: [campusId], references: [id])
  courseId    String
  course      Course         @relation(fields: [courseId], references: [id])
  teacherId   String
  teacher     TeacherProfile @relation(fields: [teacherId], references: [id])
  labId       String
  lab         Lab            @relation(fields: [labId], references: [id])
  timeSlot    TimeSlot
  days        ClassDays
  capacity    Int            @default(20)
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  enrollments Enrollment[]
  attendance  Attendance[]

  @@unique([labId, timeSlot, days])
}

model User {
  id          String   @id @default(cuid())
  clerkId     String   @unique
  role        Role
  firstName   String
  lastName    String
  email       String   @unique
  phone       String?
  avatar      String?
  gender      Gender?
  dateOfBirth DateTime?
  address     String?
  campusId    String?
  campus      Campus?  @relation(fields: [campusId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  studentProfile  StudentProfile?
  teacherProfile  TeacherProfile?

  sentReports     Report[]       @relation("ReportSender")
  receivedReports Report[]       @relation("ReportReceiver")
  notifications   Notification[]
  payments        Payment[]
  assetLogs      AssetLog[]
}

model StudentProfile {
  id               String  @id @default(cuid())
  userId           String  @unique
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentCode      String  @unique
  guardianName     String?
  guardianPhone    String?
  emergencyContact String?
  notes            String?

  enrollments  Enrollment[]
}

model TeacherProfile {
  id           String  @id @default(cuid())
  userId       String  @unique
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  teacherCode  String  @unique
  specialty    String?
  bio          String?

  classes    Class[]
}

model Course {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  description String?
  classType   ClassType
  durationWeeks Int
  fee         Float
  isActive    Boolean   @default(true)
  thumbnail   String?
  campusId    String
  campus      Campus    @relation(fields: [campusId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  enrollments  Enrollment[]
  classes      Class[]
  materials    Material[]
}

model Enrollment {
  id        String           @id @default(cuid())
  studentId String
  student   StudentProfile   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  courseId  String
  course    Course           @relation(fields: [courseId], references: [id])
  startDate DateTime
  endDate   DateTime?
  status    EnrollmentStatus @default(ACTIVE)
  classId   String?
  class     Class?           @relation(fields: [classId], references: [id])
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  attendance Attendance[]
  payments   Payment[]

  @@unique([studentId, courseId])
}

model Attendance {
  id           String           @id @default(cuid())
  enrollmentId String
  enrollment   Enrollment       @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  classId      String?
  class        Class?           @relation(fields: [classId], references: [id])
  date         DateTime
  status       AttendanceStatus @default(PRESENT)
  note         String?
  markedAt     DateTime         @default(now())

  @@unique([enrollmentId, classId, date])
}

model Payment {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  enrollmentId String
  enrollment   Enrollment    @relation(fields: [enrollmentId], references: [id])
  amount       Float
  method       PaymentMethod?
  status       PaymentStatus @default(PENDING)
  dueDate      DateTime?
  paidAt       DateTime?
  receiptUrl   String?
  note         String?
  createdAt    DateTime      @default(now())
}

model Report {
  id          String       @id @default(cuid())
  senderId    String
  sender      User         @relation("ReportSender", fields: [senderId], references: [id])
  receiverId  String
  receiver    User         @relation("ReportReceiver", fields: [receiverId], references: [id])
  studentId   String?
  title       String
  content     String
  status      ReportStatus @default(UNREAD)
  replyContent String?
  repliedAt   DateTime?
  createdAt   DateTime     @default(now())
}

model Material {
  id          String   @id @default(cuid())
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id])
  uploadedBy  String
  title       String
  fileUrl     String
  fileType    String?
  createdAt   DateTime @default(now())
}

model Notification {
  id          String             @id @default(cuid())
  userId      String
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  target      NotificationTarget
  title       String
  body        String
  isRead      Boolean            @default(false)
  createdAt   DateTime           @default(now())
}

model Certificate {
  id          String   @id @default(cuid())
  studentId   String
  courseId    String
  issuedAt    DateTime @default(now())
  fileUrl     String?
  verifyCode  String   @unique @default(cuid())
}

// Developer must run: npx prisma db push --force-reset
