generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  TEACHER
  STUDENT
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum ClassType {
  PERSONAL
  GROUP
  ONLINE
}

enum ClassStatus {
  REGISTRATION
  STARTED
  ENDED
}

enum WithdrawalStatus {
  ACTIVE
  RETURNED
  DROPPED
}

enum WaitlistStatus {
  PENDING
  JOINED
  REJECTED
}

enum TimeSlot {
  SLOT_8_10
  SLOT_10_12
  SLOT_12_2
  SLOT_3_5
  SLOT_5_7
}

enum ClassDays {
  MWF
  TTS
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  DROPPED
  ON_HOLD
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  MOBILE_MONEY
  CARD
}

enum RemainingStatus {
  PENDING
  PARTIAL
  PAID
}

enum ReportStatus {
  UNREAD
  READ
  REPLIED
}

enum NotificationTarget {
  ALL
  STUDENTS
  TEACHERS
  ADMIN
}

enum AssetCategory {
  COMPUTER
  MONITOR
  KEYBOARD
  MOUSE
  CHAIR
  TABLE
  NETWORK_SWITCH
  NETWORK_CABLE
  HEADSET
  WEBCAM
  PROJECTOR
  OTHER
}

enum AssetCondition {
  GOOD
  FAIR
  DAMAGED
  UNDER_REPAIR
  MISSING
  RETIRED
}

enum AssetLogAction {
  ADDED
  REPAIRED
  DAMAGED
  MISSING
  RETIRED
  UPDATED
  RETURNED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum RequestStatus {
  PENDING
  CONTACTED
  ENROLLED
  DECLINED
}

model Campus {
  id        String   @id @default(cuid())
  name      String   @unique
  location  String?
  isActive  Boolean  @default(true)
  color     String   @default("blue")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  courses        Course[]
  classes        Class[]
  labs           Lab[]
  cocStudents    COCStudent[]
  tasks          Task[]
  courseRequests CourseRequest[]
}

model Lab {
  id        String   @id @default(cuid())
  name      String
  campusId  String
  campus    Campus   @relation(fields: [campusId], references: [id])
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  classes Class[]
  assets  Asset[]

  @@unique([campusId, name])
}

model Asset {
  id           String         @id @default(cuid())
  labId        String
  lab          Lab            @relation(fields: [labId], references: [id], onDelete: Cascade)
  category     AssetCategory
  name         String
  serialNumber String?        @unique
  condition    AssetCondition @default(GOOD)
  notes        String?
  addedById    String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  logs AssetLog[]
}

model AssetLog {
  id        String         @id @default(cuid())
  assetId   String
  asset     Asset          @relation(fields: [assetId], references: [id], onDelete: Cascade)
  userId    String
  user      User           @relation(fields: [userId], references: [id])
  action    AssetLogAction
  note      String?
  createdAt DateTime       @default(now())
}

model Class {
  id         String         @id @default(cuid())
  campusId   String
  campus     Campus         @relation(fields: [campusId], references: [id])
  courseId   String
  course     Course         @relation(fields: [courseId], references: [id])
  teacherId  String
  teacher    TeacherProfile @relation(fields: [teacherId], references: [id])
  labId      String?
  lab        Lab?           @relation(fields: [labId], references: [id])
  timeSlot   TimeSlot
  days       ClassDays
  startDate  DateTime?
  endDate    DateTime?
  classType  ClassType      @default(GROUP)
  status     ClassStatus    @default(REGISTRATION)
  onlineLink String?
  capacity   Int            @default(20)
  isActive   Boolean        @default(true)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  enrollments Enrollment[]
  attendance  Attendance[]

  @@unique([labId, timeSlot, days])
}

model User {
  id          String    @id @default(cuid())
  clerkId     String    @unique
  role        Role
  firstName   String
  lastName    String
  email       String    @unique
  phone       String?
  telegram    String?
  whatsapp    String?
  avatar      String?
  gender      Gender?
  dateOfBirth DateTime?
  address     String?
  campusId    String?
  campus      Campus?   @relation(fields: [campusId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  studentProfile StudentProfile?
  teacherProfile TeacherProfile?
  adminSettings  AdminSettings?

  sentReports         Report[]         @relation("ReportSender")
  receivedReports     Report[]         @relation("ReportReceiver")
  notifications       Notification[]
  payments            Payment[]
  partialPayments     PartialPayment[]
  assetLogs           AssetLog[]
  approvedWithdrawals Withdrawal[]
  claimedCertificates Certificate[]    @relation("CertificateClaimedBy")
  addedCOCStudents    COCStudent[]
  createdTasks        Task[]           @relation("TaskCreator")
  assignedTasks       Task[]           @relation("TaskAssignee")
  sentMessages        Message[]        @relation("MessageSender")
  receivedMessages    Message[]        @relation("MessageReceiver")
  courseRequests      CourseRequest[]
}

model AdminSettings {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Profile
  profilePicture String?

  // Dashboard customization
  dashboardCards         String[] @default(["students", "revenue", "classes", "teachers", "attendance"])
  dashboardDefaultView   String   @default("monthly")
  dashboardPinnedActions String[] @default(["add_student", "mark_attendance", "view_remaining"])

  // Notification preferences
  emailNotifications    Boolean @default(true)
  notifyOverduePayments Boolean @default(true)
  notifyTeacherReports  Boolean @default(true)
  notifyClassEndingSoon Boolean @default(true)
  notifyClassFull       Boolean @default(true)
  notificationFrequency String  @default("instant")

  // Payment settings
  defaultCurrency           String @default("ETB")
  paymentGracePeriodDays    Int    @default(7)
  defaultCertificateFee     Float  @default(0)
  paymentReminderDaysBefore Int    @default(3)

  // Class settings
  defaultClassCapacity  Int @default(20)
  defaultCourseDuration Int @default(8)

  // Appearance
  sidebarTheme   String @default("dark")
  colorMode      String @default("system")
  accentColor    String @default("blue")
  calendarSystem String @default("gregorian")
  dateFormat     String @default("DD/MM/YYYY")
  timeFormat     String @default("12h")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StudentProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentCode      String   @unique
  guardianName     String?
  guardianPhone    String?
  emergencyContact String?
  notes            String?
  registrationDate DateTime @default(now())

  enrollments  Enrollment[]
  assessment   StudentAssessment?
  certificates Certificate[]
  cocEntries   COCStudent[]
}

model TeacherProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  teacherCode String   @unique
  specialty   String? // Deprecated: use specialties
  specialties String[] @default([])
  bio         String?

  classes Class[]
}

model Course {
  id            String    @id @default(cuid())
  title         String
  slug          String    @unique
  description   String?
  classType     ClassType
  durationWeeks Int
  fee           Float
  isActive      Boolean   @default(true)
  thumbnail     String?
  campusId      String
  campus        Campus    @relation(fields: [campusId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  enrollments  Enrollment[]
  classes      Class[]
  materials    Material[]
  certificates Certificate[]
}

model Enrollment {
  id        String           @id @default(cuid())
  studentId String
  student   StudentProfile   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  courseId  String
  course    Course           @relation(fields: [courseId], references: [id])
  startDate DateTime
  endDate   DateTime?
  status    EnrollmentStatus @default(ACTIVE)
  classId   String?
  class     Class?           @relation(fields: [classId], references: [id])
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  attendance       Attendance[]
  payments         Payment[]
  paymentRemaining PaymentRemaining?
  withdrawals      Withdrawal[]

  @@unique([studentId, courseId])
}

model Attendance {
  id           String           @id @default(cuid())
  enrollmentId String
  enrollment   Enrollment       @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  classId      String?
  class        Class?           @relation(fields: [classId], references: [id])
  date         DateTime
  status       AttendanceStatus @default(PRESENT)
  note         String?
  markedAt     DateTime         @default(now())

  @@unique([enrollmentId, classId, date])
}

model Payment {
  id           String         @id @default(cuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id])
  enrollmentId String
  enrollment   Enrollment     @relation(fields: [enrollmentId], references: [id])
  amount       Float
  method       PaymentMethod?
  status       PaymentStatus  @default(PENDING)
  dueDate      DateTime?
  paidAt       DateTime?
  receiptUrl   String?
  note         String?
  createdAt    DateTime       @default(now())
}

model PaymentRemaining {
  id              String          @id @default(cuid())
  enrollmentId    String          @unique
  enrollment      Enrollment      @relation(fields: [enrollmentId], references: [id])
  originalFee     Float
  paidAmount      Float
  remainingAmount Float
  dueDate         DateTime
  status          RemainingStatus @default(PENDING)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  partialPayments PartialPayment[]
}

model PartialPayment {
  id                 String           @id @default(cuid())
  paymentRemainingId String
  paymentRemaining   PaymentRemaining @relation(fields: [paymentRemainingId], references: [id])
  amount             Float
  method             PaymentMethod
  note               String?
  recordedById       String
  recordedBy         User             @relation(fields: [recordedById], references: [id])
  createdAt          DateTime         @default(now())
}

model Report {
  id           String       @id @default(cuid())
  senderId     String
  sender       User         @relation("ReportSender", fields: [senderId], references: [id])
  receiverId   String
  receiver     User         @relation("ReportReceiver", fields: [receiverId], references: [id])
  studentId    String?
  title        String
  content      String
  status       ReportStatus @default(UNREAD)
  replyContent String?
  repliedAt    DateTime?
  createdAt    DateTime     @default(now())
}

model Material {
  id         String   @id @default(cuid())
  courseId   String
  course     Course   @relation(fields: [courseId], references: [id])
  uploadedBy String
  title      String
  fileUrl    String
  fileType   String?
  createdAt  DateTime @default(now())
}

model Notification {
  id        String             @id @default(cuid())
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  target    NotificationTarget
  title     String
  body      String
  isRead    Boolean            @default(false)
  createdAt DateTime           @default(now())
}

model Withdrawal {
  id                 String           @id @default(cuid())
  enrollmentId       String
  enrollment         Enrollment       @relation(fields: [enrollmentId], references: [id])
  reason             String
  startDate          DateTime         @default(now())
  expectedReturnDate DateTime?
  actualReturnDate   DateTime?
  status             WithdrawalStatus @default(ACTIVE)
  approvedById       String
  approvedBy         User             @relation(fields: [approvedById], references: [id])
  notes              String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

model StudentAssessment {
  id                        String         @id @default(cuid())
  studentId                 String         @unique
  student                   StudentProfile @relation(fields: [studentId], references: [id])
  hasBasicComputerKnowledge Boolean?
  courseUnderstanding       String[]
  socialMediaPlatforms      String[]
  canCreateSimplePost       String?
  canUseBrowser             String?
  hasActiveEmail            Boolean?
  canLoginEmail             Boolean?
  hasDevice                 Boolean?
  hasInternetConnection     Boolean?
  createdAt                 DateTime       @default(now())
  updatedAt                 DateTime       @updatedAt
}

model TeacherWaitlist {
  id          String         @id @default(cuid())
  firstName   String
  lastName    String
  phone       String
  courses     String[]
  appliedDate DateTime       @default(now())
  notes       String?
  status      WaitlistStatus @default(PENDING)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model Certificate {
  id                String          @id @default(cuid())
  studentId         String?
  student           StudentProfile? @relation(fields: [studentId], references: [id])
  manualStudentName String?
  courseId          String
  course            Course          @relation(fields: [courseId], references: [id])
  issuedAt          DateTime        @default(now())
  fileUrl           String?
  verifyCode        String          @unique @default(cuid())
  claimedById       String?
  claimedBy         User?           @relation("CertificateClaimedBy", fields: [claimedById], references: [id])
  paymentStatus     PaymentStatus   @default(PENDING)
  paymentMethod     PaymentMethod?
  isDelivered       Boolean         @default(false)
  deliveredAt       DateTime?
  notes             String?
}

model COCStudent {
  id               String          @id @default(cuid())
  studentProfileId String?
  studentProfile   StudentProfile? @relation(fields: [studentProfileId], references: [id])
  fullName         String
  gender           String?
  phone            String?
  regNo            String?
  campusId         String?
  campus           Campus?         @relation(fields: [campusId], references: [id])
  paymentAmount    Float
  paymentStatus    PaymentStatus   @default(PENDING)
  paymentMethod    PaymentMethod?
  addedById        String
  addedBy          User            @relation(fields: [addedById], references: [id])
  examDate         DateTime?
  result           String?
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model Task {
  id            String       @id @default(cuid())
  title         String
  description   String?
  priority      TaskPriority @default(MEDIUM)
  status        TaskStatus   @default(PENDING)
  dueDate       DateTime?
  createdById   String
  createdBy     User         @relation("TaskCreator", fields: [createdById], references: [id])
  assigneeId    String?
  assignee      User?        @relation("TaskAssignee", fields: [assigneeId], references: [id])
  completedAt   DateTime?
  completedNote String?
  campusId      String?
  campus        Campus?      @relation(fields: [campusId], references: [id])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Message {
  id         String    @id @default(cuid())
  senderId   String
  sender     User      @relation("MessageSender", fields: [senderId], references: [id])
  receiverId String
  receiver   User      @relation("MessageReceiver", fields: [receiverId], references: [id])
  subject    String
  body       String
  isRead     Boolean   @default(false)
  readAt     DateTime?
  parentId   String?
  parent     Message?  @relation("MessageThread", fields: [parentId], references: [id])
  replies    Message[] @relation("MessageThread")
  createdAt  DateTime  @default(now())
}

model CourseRequest {
  id         String        @id @default(cuid())
  firstName  String
  lastName   String
  phone      String
  courseName String
  notes      String?
  status     RequestStatus @default(PENDING)
  campusId   String?
  campus     Campus?       @relation(fields: [campusId], references: [id])
  addedById  String
  addedBy    User          @relation(fields: [addedById], references: [id])
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

// Developer must run: npx prisma db push
